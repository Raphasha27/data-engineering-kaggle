{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {"id": "title"},
   "source": [
    "# Titanic: Machine Learning from Disaster\n",
    "**Author:** Koketso Raphasha | [Kaggle: Raphasha27](https://kaggle.com/Raphasha27)\n",
    "\n",
    "**Best Public Score:** 78.5% (v6) → targeting 80%+ with family survival features\n",
    "\n",
    "**Approach:** Feature engineering with KNN imputation, family survival rates (leave-one-out), interaction features, tuned GradientBoosting + XGBoost ensemble"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "imports"},
   "source": [
    "import warnings\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.model_selection import StratifiedKFold, cross_val_score\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.impute import KNNImputer\n",
    "from sklearn.ensemble import GradientBoostingClassifier, RandomForestClassifier, VotingClassifier\n",
    "from xgboost import XGBClassifier\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "sns.set_style('darkgrid')\n",
    "plt.rcParams['figure.figsize'] = (12, 6)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "load"},
   "source": [
    "train = pd.read_csv('/kaggle/input/titanic/train.csv')\n",
    "test = pd.read_csv('/kaggle/input/titanic/test.csv')\n",
    "print(f'Train: {train.shape[0]} rows x {train.shape[1]} cols')\n",
    "print(f'Test:  {test.shape[0]} rows x {test.shape[1]} cols')\n",
    "print(f'\\nMissing:\\n{train.isnull().sum()}')
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "eda"},
   "source": [
    "## Exploratory Data Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "eda_plots"},
   "source": [
    "fig, axes = plt.subplots(2, 3, figsize=(15, 10))\n",
    "sns.countplot(data=train, x='Survived', ax=axes[0,0])\n",
    "axes[0,0].set_title('Survival Distribution')\n",
    "sns.countplot(data=train, x='Sex', hue='Survived', ax=axes[0,1])\n",
    "axes[0,1].set_title('Survival by Sex')\n",
    "sns.histplot(data=train, x='Age', hue='Survived', kde=True, bins=30, ax=axes[0,2])\n",
    "axes[0,2].set_title('Age Distribution')\n",
    "sns.countplot(data=train, x='Pclass', hue='Survived', ax=axes[1,0])\n",
    "axes[1,0].set_title('Survival by Class')\n",
    "sns.countplot(data=train, x='Embarked', hue='Survived', ax=axes[1,1])\n",
    "axes[1,1].set_title('Survival by Embarked')\n",
    "sns.boxplot(data=train, x='Survived', y='Fare', ax=axes[1,2])\n",
    "axes[1,2].set_title('Fare by Survival')\n",
    "plt.tight_layout()\n",
    "plt.savefig('eda.png', dpi=100)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "fe"},
   "source": [
    "## Feature Engineering"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "features"},
   "source": [
    "def base_features(df):\n",
    "    data = df.copy()\n",
    "    data['Title'] = data['Name'].str.extract(r' ([A-Za-z]+)\\.', expand=False)\n",
    "    data['Title'] = data['Title'].map({'Mr':'Mr','Miss':'Miss','Mrs':'Mrs','Master':'Master'}).fillna('Rare')\n",
    "    data['Title'] = data['Title'].map({'Mr':0,'Miss':1,'Mrs':2,'Master':3,'Rare':4}).fillna(4).astype(int)\n",
    "    data['FamilySize'] = data['SibSp'] + data['Parch'] + 1\n",
    "    data['IsAlone'] = (data['FamilySize'] == 1).astype(int)\n",
    "    data['HasCabin'] = data['Cabin'].notna().astype(int)\n",
    "    data['Sex'] = (data['Sex'] == 'male').astype(int)\n",
    "    data['Embarked'] = data['Embarked'].fillna('S').map({'S':0,'C':1,'Q':2}).fillna(0).astype(int)\n",
    "    data['Pclass'] = data['Pclass'].astype(int)\n",
    "    data['Surname'] = data['Name'].str.extract(r'^([A-Za-z]+)', expand=False)\n",
    "    return data\n",
    "\n",
    "full_bf = base_features(pd.concat([train.drop('Survived', axis=1), test], ignore_index=True))\n",
    "\n",
    "# Leave-one-out family survival rate\n",
    "train_bf = full_bf.iloc[:len(train)].copy()\n",
    "train_bf['Survived'] = train['Survived'].values\n",
    "grp = train_bf.groupby(['Surname', 'Ticket'])['Survived']\n",
    "train_bf['FamilyCount'] = grp.transform('count')\n",
    "train_bf['FamilySum'] = grp.transform('sum')\n",
    "train_bf['FamilySurvivalRate'] = np.where(\n",
    "    train_bf['FamilyCount'] > 1,\n",
    "    (train_bf['FamilySum'] - train_bf['Survived']) / (train_bf['FamilyCount'] - 1), 0.5\n",
    ").clip(0, 1)\n",
    "\n",
    "family_stats = train_bf.groupby(['Surname', 'Ticket']).agg(\n",
    "    FamilySurvivalRate_lookup=('Survived', 'mean'),\n",
    "    FamilyCount_lookup=('Survived', 'count')\n",
    ").reset_index()\n",
    "\n",
    "test_bf = full_bf.iloc[len(train):].merge(family_stats, on=['Surname','Ticket'], how='left')\n",
    "test_bf['FamilySurvivalRate'] = test_bf['FamilySurvivalRate_lookup'].fillna(0.5)\n",
    "test_bf['FamilyCount'] = test_bf['FamilyCount_lookup'].fillna(1).astype(int)\n",
    "\n",
    "train_feat = train_bf[['Pclass','Sex','Age','SibSp','Parch','Fare','Embarked','Title',\n",
    "    'FamilySize','IsAlone','HasCabin','FamilySurvivalRate','FamilyCount']].copy()\n",
    "test_feat = test_bf[['Pclass','Sex','Age','SibSp','Parch','Fare','Embarked','Title',\n",
    "    'FamilySize','IsAlone','HasCabin','FamilySurvivalRate','FamilyCount']].copy()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "impute"},
   "source": [
    "## Imputation & Interactions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "impute_code"},
   "source": [
    "full_imp = pd.concat([train_feat, test_feat], ignore_index=True)\n",
    "age_cols = ['Age','Pclass','Sex','Fare','SibSp','Parch','Title','FamilySize']\n",
    "knn = KNNImputer(n_neighbors=7)\n",
    "full_imp['Age'] = pd.DataFrame(knn.fit_transform(full_imp[age_cols]), columns=age_cols)['Age']\n",
    "fare_med = full_imp.groupby('Pclass')['Fare'].transform('median')\n",
    "full_imp['Fare'] = full_imp['Fare'].fillna(fare_med)\n",
    "\n",
    "full_imp['Age_Pclass'] = full_imp['Age'] * full_imp['Pclass']\n",
    "full_imp['Fare_Pclass'] = full_imp['Fare'] / (full_imp['Pclass'] + 1)\n",
    "full_imp['FamSurv_Age'] = full_imp['FamilySurvivalRate'] * full_imp['Age'] / 10\n",
    "\n",
    "feat_cols = ['Pclass','Sex','Age','SibSp','Parch','Fare','Embarked','Title',\n",
    "    'FamilySize','IsAlone','HasCabin','FamilySurvivalRate','FamilyCount',\n",
    "    'Age_Pclass','Fare_Pclass','FamSurv_Age']\n",
    "\n",
    "X_full = full_imp.iloc[:len(train)][feat_cols]\n",
    "X_test = full_imp.iloc[len(train):][feat_cols]\n",
    "y_full = train['Survived'].values\n",
    "\n",
    "scaler = StandardScaler()\n",
    "X_full_s = scaler.fit_transform(X_full)\n",
    "X_test_s = scaler.transform(X_test)\n",
    "print(f'Features: {len(feat_cols)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "model"},
   "source": [
    "## Model Training"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "train_model"},
   "source": [
    "cv = StratifiedKFold(n_splits=10, shuffle=True, random_state=42)\n",
    "\n",
    "models = {\n",
    "    'GB': GradientBoostingClassifier(n_estimators=200, max_depth=3, learning_rate=0.035,\n",
    "                                      subsample=0.75, min_samples_leaf=4, random_state=42),\n",
    "    'XGB': XGBClassifier(n_estimators=400, max_depth=3, learning_rate=0.02, subsample=0.75,\n",
    "                          colsample_bytree=0.75, reg_lambda=3.0, reg_alpha=2.0, eval_metric='logloss', random_state=42),\n",
    "}\n",
    "\n",
    "for name, model in models.items():\n",
    "    scores = cross_val_score(model, X_full_s, y_full, cv=cv, scoring='accuracy')\n",
    "    print(f'{name}: CV {scores.mean():.4f} (+/- {scores.std()*2:.4f})')\n",
    "\n",
    "# Weighted ensemble\n",
    "test_probs = np.zeros((X_test.shape[0], len(models)))\n",
    "for i, (name, model) in enumerate(models.items()):\n",
    "    model.fit(X_full_s, y_full)\n",
    "    test_probs[:, i] = model.predict_proba(X_test_s)[:, 1]\n",
    "\n",
    "preds = (test_probs.mean(axis=1) > 0.5).astype(int)\n",
    "print(f'\\nSurvived: {preds.sum()}/{len(preds)} ({preds.mean()*100:.1f}%)')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {"id": "submit"},
   "source": [
    "## Submission"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {"id": "submit_code"},
   "source": [
    "sub = pd.DataFrame({'PassengerId': test['PassengerId'], 'Survived': preds})\n",
    "sub.to_csv('submission.csv', index=False)\n",
    "print('Ready: submission.csv')\n",
    "sub.head()"
   ]
  }
 ],
